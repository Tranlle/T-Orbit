<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.KeyMap.ViewModels"
             xmlns:views="using:TOrbit.Plugin.KeyMap.Views"
             xmlns:designer="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Plugin.KeyMap.Views.KeyMapView"
             x:DataType="vm:KeyMapViewModel">

  <UserControl.Styles>
    <Style Selector="Button.binding-item">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusMedium}" />
    </Style>
    <Style Selector="Button.binding-item:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceHoverBrush}" />
    </Style>
    <Style Selector="Button.binding-item.selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TOrbitAccentSubtleBrush}" />
    </Style>
  </UserControl.Styles>

  <designer:ToolPageLayout HeaderBodyGapHeight="0"
                           BodyFooterGapHeight="0"
                           FooterHeight="0">
    <designer:ToolPageLayout.BodyContent>
      <designer:SplitWorkspace LeftWidth="340"
                               LeftMinWidth="260"
                               RightMinWidth="420">
        <designer:SplitWorkspace.LeftContent>
          <Border Classes="workspace-panel">
            <Grid RowDefinitions="Auto,*,Auto">
              <StackPanel Margin="20,20,20,16"
                          Spacing="12">
                <TextBox Classes="form-control"
                         Text="{Binding SearchText, Mode=TwoWay}"
                         PlaceholderText="搜索快捷键..."
                         FontSize="13" />
              </StackPanel>

              <ScrollViewer Grid.Row="1"
                            Margin="20,0,20,0"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Groups}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:KeyMapGroupViewModel">
                      <StackPanel Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="2,0,2,8">
                          <TextBlock Text="{Binding PluginName}"
                                     Classes="section-title"
                                     VerticalAlignment="Center" />
                          <Border Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                                  BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="8,3">
                            <TextBlock Text="{Binding Count}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TOrbitTextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                          </Border>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Bindings}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:KeyMapBindingViewModel">
                              <Button Classes="binding-item"
                                      Classes.selected="{Binding IsSelected}"
                                      Command="{Binding $parent[UserControl].((vm:KeyMapViewModel)DataContext).SelectBindingCommand}"
                                      CommandParameter="{Binding}">
                                <Border Background="Transparent"
                                        BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                                        Padding="12,11"
                                        MinHeight="48">
                                  <Grid ColumnDefinitions="*,Auto"
                                        ColumnSpacing="10">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <designer:StatusBadge Grid.Column="1"
                                                          Text="{Binding CurrentKeyDisplay}"
                                                          BadgeBackground="{DynamicResource TOrbitSurfaceElevatedBrush}"
                                                          BadgeForeground="{DynamicResource TOrbitTextMutedBrush}"
                                                          VerticalAlignment="Center" />
                                  </Grid>
                                </Border>
                              </Button>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <Border Grid.Row="2"
                      Margin="20,16,20,20"
                      Background="{DynamicResource TOrbitSurfaceBrush}"
                      BorderBrush="{DynamicResource TOrbitBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                      Padding="12,10">
                <TextBlock Text="修改后的绑定会立即反映到列表中，并覆盖默认配置。"
                           Classes="caption-muted"
                           MinHeight="0"
                           TextWrapping="Wrap" />
              </Border>
            </Grid>
          </Border>
        </designer:SplitWorkspace.LeftContent>

        <designer:SplitWorkspace.RightContent>
          <Border Classes="workspace-panel">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <Panel Margin="20">
                <designer:EmptyState IsVisible="{Binding SelectedBinding, Converter={x:Static ObjectConverters.IsNull}}"
                                     Title="选择一个快捷键"
                                     Description="从左侧列表选择一条绑定后，可在这里查看并编辑详情。" />

                <ContentControl Content="{Binding SelectedBinding}"
                                IsVisible="{Binding SelectedBinding, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <ContentControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:KeyMapBindingViewModel">
                      <StackPanel Spacing="18">
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="18"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                          <TextBlock Text="{Binding Description}"
                                     Classes="caption-muted"
                                     MinHeight="0"
                                     TextWrapping="Wrap"
                                     IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                          <Border Classes="card"
                                  Padding="14,12">
                            <StackPanel Spacing="4">
                              <TextBlock Text="所属插件"
                                         Classes="caption-muted"
                                         MinHeight="0" />
                              <TextBlock Text="{Binding PluginName}"
                                         FontSize="16"
                                         FontWeight="SemiBold" />
                            </StackPanel>
                          </Border>
                          <Border Grid.Column="1"
                                  Classes="card"
                                  Padding="14,12">
                            <StackPanel Spacing="4">
                              <TextBlock Text="默认绑定"
                                         Classes="caption-muted"
                                         MinHeight="0" />
                              <TextBlock Text="{Binding DefaultKey}"
                                         FontFamily="{DynamicResource TOrbitMonoFontFamily}"
                                         FontSize="16"
                                         FontWeight="SemiBold" />
                            </StackPanel>
                          </Border>
                        </Grid>

                        <Border Classes="card"
                                Padding="18">
                          <StackPanel Spacing="16">
                            <StackPanel Spacing="2">
                              <TextBlock Text="当前绑定"
                                         Classes="section-title" />
                              <TextBlock Text="聚焦输入框后直接按下新的组合键，按 Esc 可取消本次录入。"
                                         Classes="caption-muted"
                                         MinHeight="0"
                                         TextWrapping="Wrap" />
                            </StackPanel>

                            <views:KeyCaptureBox Value="{Binding CurrentKeyDisplay, Mode=TwoWay}" />

                            <Border IsVisible="{Binding IsModified}"
                                    Background="{DynamicResource TOrbitBadgeInfoBackgroundBrush}"
                                    BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                                    Padding="12,10">
                              <TextBlock Text="当前绑定已覆盖默认值。"
                                         Foreground="{DynamicResource TOrbitBadgeInfoForegroundBrush}"
                                         FontSize="12"
                                         TextWrapping="Wrap" />
                            </Border>

                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="12"
                                  VerticalAlignment="Center">
                              <StackPanel Spacing="3">
                                <TextBlock Text="启用状态"
                                           Classes="subsection-title" />
                                <TextBlock Text="关闭后该绑定不会参与当前运行时的快捷键处理。"
                                           Classes="caption-muted"
                                           MinHeight="0"
                                           TextWrapping="Wrap" />
                              </StackPanel>
                              <ToggleSwitch Grid.Column="1"
                                            IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                            VerticalAlignment="Center" />
                              <Button Grid.Column="2"
                                      Command="{Binding ResetCommand}"
                                      Content="恢复默认"
                                      VerticalAlignment="Center" />
                            </Grid>
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </DataTemplate>
                  </ContentControl.ContentTemplate>
                </ContentControl>
              </Panel>
            </ScrollViewer>
          </Border>
        </designer:SplitWorkspace.RightContent>
      </designer:SplitWorkspace>
    </designer:ToolPageLayout.BodyContent>
  </designer:ToolPageLayout>
</UserControl>
