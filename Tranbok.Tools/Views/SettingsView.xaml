<UserControl x:Class="Tranbok.Tools.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{StaticResource BgCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BgDefaultBrush}"
                BorderBrush="{StaticResource BorderMutedBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,0">
            <TextBlock Text="设置"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource FgDefaultBrush}"
                       VerticalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource BgDefaultBrush}"
                        BorderBrush="{StaticResource BorderMutedBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="基础设置"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgDefaultBrush}"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="应用名称" Foreground="{StaticResource FgSubtleBrush}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding AppName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="主题" Foreground="{StaticResource FgSubtleBrush}" Margin="0,0,0,6"/>
                        <ComboBox SelectedValue="{Binding Theme, Mode=TwoWay}" SelectedValuePath="Content" Margin="0,0,0,12">
                            <ComboBoxItem Content="Dark"/>
                            <ComboBoxItem Content="Light"/>
                        </ComboBox>

                        <CheckBox Content="迁移默认启用 Workspace 模式"
                                  IsChecked="{Binding UseWorkspaceForMigrations, Mode=TwoWay}"
                                  Foreground="{StaticResource FgDefaultBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{StaticResource BgDefaultBrush}"
                        BorderBrush="{StaticResource BorderMutedBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="工作区设置"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgDefaultBrush}"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Workspace 根目录" Foreground="{StaticResource FgSubtleBrush}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding WorkspaceRoot, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="说明" Foreground="{StaticResource FgSubtleBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="当前设置页已接入真实界面结构，后续可继续接入持久化配置文件。"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource FgDefaultBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{StaticResource BgDefaultBrush}"
                BorderBrush="{StaticResource BorderMutedBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource FgSubtleBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="重置" Command="{Binding ResetCommand}" Margin="0,0,8,0"/>
                    <Button Content="保存" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
