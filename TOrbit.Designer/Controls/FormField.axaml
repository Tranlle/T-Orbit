<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Designer.Controls.FormField"
             x:DataType="controls:FormField"
             x:Name="Root">
  <StackPanel Spacing="8">
    <StackPanel Spacing="2">
      <TextBlock Classes="form-label"
                 Text="{Binding Label, ElementName=Root}" />
      <TextBlock x:Name="DescriptionText"
                 Classes="caption-muted"
                 MinHeight="0"
                 Text="{Binding Description, ElementName=Root}"
                 TextWrapping="Wrap" />
    </StackPanel>

    <ContentPresenter Content="{Binding Body, ElementName=Root}" />
  </StackPanel>
</UserControl>
