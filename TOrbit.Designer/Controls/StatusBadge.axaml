<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Designer.Controls.StatusBadge"
             x:DataType="controls:StatusBadge"
             x:Name="Root">
  <Border Background="{Binding BadgeBackground, ElementName=Root}"
          BorderBrush="{DynamicResource TOrbitBorderBrush}"
          BorderThickness="1"
          CornerRadius="999"
          Padding="10,4"
          VerticalAlignment="Center">
    <TextBlock Text="{Binding Text, ElementName=Root}"
               Foreground="{Binding BadgeForeground, ElementName=Root}"
               FontSize="11"
               FontWeight="Medium"
               LetterSpacing="0.2"
               LineHeight="14"
               VerticalAlignment="Center" />
  </Border>
</UserControl>
