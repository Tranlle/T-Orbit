<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Designer.Controls.SectionHeader"
             x:DataType="controls:SectionHeader"
             x:Name="Root">
  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">

    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
      <TextBlock x:Name="EyebrowText"
                 Classes="eyebrow"
                 Text="{Binding Eyebrow, ElementName=Root}" />
      <TextBlock Classes="page-title"
                 Text="{Binding Title, ElementName=Root}" />
      <TextBlock Classes="caption-muted"
                 Text="{Binding Description, ElementName=Root}"
                 TextWrapping="Wrap"
                 MinHeight="0" />
    </StackPanel>

    <!-- Right: optional action content -->
    <ContentPresenter Grid.Column="1"
                      Content="{Binding ActionContent, ElementName=Root}"
                      VerticalAlignment="Center" />

  </Grid>
</UserControl>
