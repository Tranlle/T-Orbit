<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.SubtitleTranslator.ViewModels"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:loc="using:TOrbit.Designer.Markup"
             x:Class="TOrbit.Plugin.SubtitleTranslator.Views.SubtitleTranslatorView"
             x:DataType="vm:SubtitleTranslatorViewModel">

  <UserControl.Styles>
    <Style Selector="Border.stage-panel">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Offset="0" Color="#121A22" />
          <GradientStop Offset="1" Color="#0B1118" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#253444" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="26" />
      <Setter Property="Padding" Value="28" />
    </Style>

    <Style Selector="Border.signal-chip">
      <Setter Property="Background" Value="#101A24" />
      <Setter Property="BorderBrush" Value="#2C4258" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style Selector="Border.side-strip">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="TextBlock.stage-label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#93AFC7" />
      <Setter Property="LetterSpacing" Value="1.6" />
    </Style>
  </UserControl.Styles>

  <designer:ToolPageLayout FooterHeight="0"
                           BodyFooterGapHeight="0">
    <designer:ToolPageLayout.BodyContent>
      <designer:SplitWorkspace LeftWidth="*"
                               LeftMinWidth="520"
                               RightMinWidth="280">
        <designer:SplitWorkspace.LeftContent>
          <Grid RowDefinitions="*,Auto"
                RowSpacing="14">
            <Border Classes="stage-panel">
              <Grid RowDefinitions="Auto,*,Auto"
                    RowSpacing="18">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{loc:Loc subtitle.ui.eyebrow}"
                               Classes="stage-label" />
                    <TextBlock Text="{loc:Loc subtitle.ui.title}"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding WorkspaceHint}"
                               MaxWidth="560"
                               FontSize="13"
                               Foreground="#B3C4D6"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <Border Grid.Column="1"
                          Classes="signal-chip"
                          VerticalAlignment="Top">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{loc:Loc subtitle.ui.state}"
                                 Classes="stage-label" />
                      <TextBlock Text="{Binding RunStateText}"
                                 FontSize="13"
                                 FontWeight="SemiBold" />
                    </StackPanel>
                  </Border>
                </Grid>

                <Grid Grid.Row="1"
                      RowDefinitions="*,*"
                      RowSpacing="14">
                  <Border Background="#0D141B"
                          BorderBrush="#223141"
                          BorderThickness="1"
                          CornerRadius="22"
                          Padding="22">
                    <StackPanel Spacing="10">
                      <TextBlock Text="{loc:Loc subtitle.ui.source}"
                                 Classes="stage-label" />
                      <TextBlock Text="{Binding CurrentSourceText}"
                                 FontSize="24"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Row="1"
                          Background="#0B1016"
                          BorderBrush="#1F2B39"
                          BorderThickness="1"
                          CornerRadius="22"
                          Padding="22">
                    <StackPanel Spacing="10">
                      <TextBlock Text="{loc:Loc subtitle.ui.translation}"
                                 Classes="stage-label" />
                      <Border Background="#101722"
                              BorderBrush="#233244"
                              BorderThickness="1"
                              CornerRadius="999"
                              Padding="10,4"
                              HorizontalAlignment="Left">
                        <TextBlock Text="{Binding TranslationStatusText}"
                                   FontSize="11"
                                   Foreground="#AFC3D8" />
                      </Border>
                      <TextBlock Text="{Binding CurrentTranslatedText}"
                                 FontSize="22"
                                 FontWeight="Medium"
                                 Foreground="#DDE8F2"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="Auto,Auto,*"
                      ColumnSpacing="10">
                  <Border Classes="signal-chip">
                    <TextBlock Text="{Binding SelectedRegionText}"
                               FontSize="12"
                               Foreground="#B8C8D9" />
                  </Border>

                  <Border Grid.Column="1"
                          Classes="signal-chip">
                    <TextBlock Text="{Binding LastUpdatedText}"
                               FontSize="12"
                               Foreground="#B8C8D9" />
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="1"
                    Classes="workspace-panel"
                    Padding="18">
              <Grid RowDefinitions="Auto,Auto"
                    RowSpacing="10">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                  <TextBlock Text="{loc:Loc subtitle.ui.runLog}"
                             Classes="section-title"
                             VerticalAlignment="Top" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding StatusText}"
                             Classes="caption-muted"
                             MinHeight="0"
                             TextWrapping="Wrap" />
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{Binding LogSummaryText}"
                           FontFamily="{DynamicResource TOrbitMonoFontFamily}"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </Grid>
            </Border>
          </Grid>
        </designer:SplitWorkspace.LeftContent>

        <designer:SplitWorkspace.RightContent>
          <StackPanel Spacing="14">
            <Border Classes="side-strip">
              <StackPanel Spacing="14">
                <StackPanel Spacing="4">
                  <TextBlock Text="{loc:Loc subtitle.ui.controls}"
                             Classes="stage-label" />
                  <TextBlock Text="{loc:Loc subtitle.ui.actions}"
                             FontSize="18"
                             FontWeight="SemiBold" />
                </StackPanel>

                <Button Content="{loc:Loc subtitle.actions.selectRegion}"
                        Command="{Binding SelectRegionCommand}" />
                <Button Content="{loc:Loc subtitle.actions.start}"
                        Command="{Binding StartCommand}" />
                <Button Content="{loc:Loc subtitle.actions.pause}"
                        Command="{Binding PauseCommand}" />
              </StackPanel>
            </Border>

            <Border Classes="side-strip">
              <StackPanel Spacing="12">
                <TextBlock Text="{loc:Loc subtitle.ui.statusRail}"
                           Classes="stage-label" />

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <TextBlock Text="{loc:Loc subtitle.header.region}"
                             Classes="caption-muted"
                             MinHeight="0" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding RegionStateText}"
                             FontWeight="SemiBold" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <TextBlock Text="{loc:Loc subtitle.header.pipeline}"
                             Classes="caption-muted"
                             MinHeight="0" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding PipelineStateText}"
                             FontWeight="SemiBold" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <TextBlock Text="{loc:Loc subtitle.header.ocr}"
                             Classes="caption-muted"
                             MinHeight="0" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding OcrStatusText}"
                             FontWeight="SemiBold" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <TextBlock Text="{loc:Loc subtitle.header.translation}"
                             Classes="caption-muted"
                             MinHeight="0" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding TranslationStatusText}"
                             FontWeight="SemiBold" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <TextBlock Text="{loc:Loc subtitle.header.interval}"
                             Classes="caption-muted"
                             MinHeight="0" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding SampleIntervalMs, StringFormat='{}{0} ms'}"
                             FontWeight="SemiBold" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <TextBlock Text="{loc:Loc subtitle.header.lastUpdate}"
                             Classes="caption-muted"
                             MinHeight="0" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding LastUpdatedText}"
                             FontWeight="SemiBold" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Classes="side-strip">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding EmptyStateTitle}"
                           Classes="stage-label" />
                <TextBlock Text="{Binding EmptyStateDescription}"
                           Classes="caption-muted"
                           MinHeight="0"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </designer:SplitWorkspace.RightContent>
      </designer:SplitWorkspace>
    </designer:ToolPageLayout.BodyContent>
  </designer:ToolPageLayout>
</UserControl>
