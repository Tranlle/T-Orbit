<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Migration.ViewModels"
             xmlns:models="using:TOrbit.Plugin.Migration.Models"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:DataType="vm:MigrationViewModel"
             x:Class="TOrbit.Plugin.Migration.Views.MigrationView">
  <UserControl.Styles>
    <Style Selector="Button.profile-item">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusMedium}" />
    </Style>

    <Style Selector="Button.profile-item:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceHoverBrush}" />
    </Style>

    <Style Selector="Button.profile-item.selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TOrbitAccentSubtleBrush}" />
    </Style>

    <Style Selector="Border.action-cluster">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusMedium}" />
      <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Button.compact-action">
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,0" />
    </Style>

    <Style Selector="Button.icon-action">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Border.migration-hero">
      <Setter Property="Background" Value="#101B24" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusXLarge}" />
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="Border.metric-surface">
      <Setter Property="Background" Value="#101923" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusLarge}" />
      <Setter Property="Padding" Value="14,12" />
    </Style>
  </UserControl.Styles>

  <designer:ToolPageLayout FooterHeight="196">
    <designer:ToolPageLayout.BodyContent>
      <designer:SplitWorkspace LeftWidth="360"
                               LeftMinWidth="300"
                               RightMinWidth="520">
        <designer:SplitWorkspace.LeftContent>
          <Border Classes="workspace-panel">
            <Grid RowDefinitions="Auto,*,Auto">
              <StackPanel Margin="20,20,20,16"
                          Spacing="14">
                <Border Classes="migration-hero">
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="16">
                    <StackPanel Spacing="6">
                      <TextBlock Text="PROFILES"
                                 Classes="eyebrow" />
                      <TextBlock Text="Connection profiles"
                                 FontSize="20"
                                 FontWeight="SemiBold" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Top">
                      <Button Classes="icon-action"
                              ToolTip.Tip="Add profile"
                              Command="{Binding AddProfileCommand}">
                        <materialIcons:MaterialIcon Kind="Plus" Width="16" Height="16" />
                      </Button>
                      <Button Classes="icon-action"
                              ToolTip.Tip="Edit profile"
                              Command="{Binding OpenEditProfileCommand}">
                        <materialIcons:MaterialIcon Kind="PencilOutline" Width="16" Height="16" />
                      </Button>
                      <Button Classes="icon-action danger"
                              ToolTip.Tip="Delete profile"
                              Command="{Binding DeleteProfileCommand}">
                        <materialIcons:MaterialIcon Kind="TrashCanOutline" Width="16" Height="16" />
                      </Button>
                      <Button Classes="icon-action"
                              ToolTip.Tip="Refresh profiles"
                              Command="{Binding RefreshCommand}">
                        <materialIcons:MaterialIcon Kind="Refresh" Width="16" Height="16" />
                      </Button>
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>

              <ScrollViewer Grid.Row="1"
                            Margin="20,0,20,0"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DbProfiles}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:DbConnectionProfile">
                      <Button Classes="profile-item"
                              Classes.selected="{Binding IsSelected}"
                              Command="{Binding $parent[UserControl].((vm:MigrationViewModel)DataContext).SelectProfileCommand}"
                              CommandParameter="{Binding}">
                        <Border Background="Transparent"
                                BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource TOrbitRadiusLarge}"
                                Padding="14,12"
                                MinHeight="76">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="10"
                                VerticalAlignment="Center">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding EffectiveProfileName}"
                                         FontSize="14"
                                         FontWeight="SemiBold"
                                         VerticalAlignment="Center"
                                         TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center">
                              <designer:StatusBadge Text="{Binding DbTypeTag}"
                                                    BadgeBackground="{DynamicResource TOrbitAccentSubtleBrush}"
                                                    BadgeForeground="{DynamicResource TOrbitAccentSubtleForegroundBrush}"
                                                    VerticalAlignment="Center" />
                              <designer:StatusBadge Text="{Binding ReadyStatusText}"
                                                    BadgeBackground="{Binding ReadyBadgeBackground}"
                                                    BadgeForeground="{Binding ReadyBadgeForeground}"
                                                    VerticalAlignment="Center" />
                            </StackPanel>
                          </Grid>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <Border Grid.Row="2"
                      Margin="20,16,20,20"
                      Background="{DynamicResource TOrbitSurfaceBrush}"
                      BorderBrush="{DynamicResource TOrbitBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                      Padding="12,10">
                <StackPanel Spacing="4">
                  <TextBlock Text="Output directory"
                             Classes="subsection-title" />
                  <TextBlock Text="{Binding OutputDirectory, StringFormat='{}{0}'}"
                             Classes="caption-muted"
                             MinHeight="0"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>
          </Border>
        </designer:SplitWorkspace.LeftContent>

        <designer:SplitWorkspace.RightContent>
          <Border Classes="workspace-panel">
            <Grid RowDefinitions="Auto,Auto,*">
              <StackPanel Margin="20,20,20,16"
                          Spacing="18">
                <Border Classes="migration-hero">
                  <StackPanel Spacing="6">
                    <TextBlock Text="ACTIVE PROFILE"
                               Classes="eyebrow" />
                    <TextBlock Text="Migration workspace"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Review profile properties, inspect migration files, and execute schema actions without leaving the current workspace."
                               Classes="caption-muted"
                               MinHeight="0"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="12">
                  <Border Classes="metric-surface">
                    <StackPanel Spacing="4">
                      <TextBlock Text="Database"
                                 Classes="caption-muted"
                                 MinHeight="0" />
                      <TextBlock Text="{Binding CurrentDatabaseTypeDisplay}"
                                 FontSize="16"
                                 FontWeight="SemiBold" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="1"
                          Classes="metric-surface">
                    <StackPanel Spacing="4">
                      <TextBlock Text="Migrations"
                                 Classes="caption-muted"
                                 MinHeight="0" />
                      <TextBlock Text="{Binding MigrationCount}"
                                 FontSize="16"
                                 FontWeight="SemiBold" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="2"
                          Classes="metric-surface">
                    <StackPanel Spacing="4">
                      <TextBlock Text="Status"
                                 Classes="caption-muted"
                                 MinHeight="0" />
                      <TextBlock Text="{Binding StatusMessage}"
                                 FontSize="16"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Border>
                </Grid>

                <designer:PropertyGrid ItemsSource="{Binding ActiveProfileProperties}"
                                       LabelColumnWidth="140" />
              </StackPanel>

              <Border Grid.Row="1"
                      Margin="20,0,20,0"
                      BorderBrush="{DynamicResource TOrbitBorderBrush}"
                      BorderThickness="0,1,0,0" />

              <Grid Grid.Row="2"
                    Margin="20,16,20,20"
                    RowDefinitions="Auto"
                    RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <designer:EditorHeader Title="Migration actions">
                    <designer:EditorHeader.ActionContent>
                      <Button Content="Open migration file"
                              Command="{Binding OpenMigrationFileCommand}"
                              IsEnabled="{Binding HasSelectedMigration}" />
                    </designer:EditorHeader.ActionContent>
                  </designer:EditorHeader>

                  <StackPanel Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="8"
                              VerticalAlignment="Center">
                    <Border Classes="action-cluster">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="8">
                        <Button Classes="compact-action"
                                Content="New migration"
                                Command="{Binding ShowNewPanelCommand}" />
                        <Button Classes="compact-action danger"
                                Content="Remove migration"
                                Command="{Binding RollbackSelectedCommand}"
                                ToolTip.Tip="{Binding RollbackTooltip}"
                                IsEnabled="{Binding CanRollback}" />
                      </StackPanel>
                    </Border>

                    <Button Classes="compact-action accent"
                            Content="Apply update"
                            Command="{Binding ExecuteUpdateCommand}"
                            IsEnabled="{Binding IsIdle}" />
                    <Button Classes="compact-action"
                            Content="Cancel"
                            Command="{Binding CancelOperationCommand}"
                            IsVisible="{Binding IsBusy}" />
                  </StackPanel>
                </Grid>
              </Grid>
            </Grid>
          </Border>
        </designer:SplitWorkspace.RightContent>
      </designer:SplitWorkspace>
    </designer:ToolPageLayout.BodyContent>

    <designer:ToolPageLayout.FooterContent>
      <designer:LogViewer Title="Execution log"
                          Description="Review the latest migration execution and file operation output."
                          Text="{Binding OutputLog}">
        <designer:LogViewer.ActionContent>
          <Button Content="Clear log" Command="{Binding ClearLogCommand}" />
        </designer:LogViewer.ActionContent>
      </designer:LogViewer>
    </designer:ToolPageLayout.FooterContent>
  </designer:ToolPageLayout>
</UserControl>
