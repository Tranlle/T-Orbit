<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Migration.ViewModels"
             xmlns:models="using:TOrbit.Plugin.Migration.Models"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:DataType="vm:MigrationViewModel"
             x:Class="TOrbit.Plugin.Migration.Views.MigrationView">
  <UserControl.Styles>
    <Style Selector="Button.profile-item">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusMedium}" />
    </Style>
    <Style Selector="Button.profile-item:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceHoverBrush}" />
    </Style>
    <Style Selector="Button.profile-item.selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TOrbitAccentSubtleBrush}" />
    </Style>
    <Style Selector="Border.action-cluster">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusMedium}" />
      <Setter Property="Padding" Value="12" />
    </Style>
    <Style Selector="Button.compact-action">
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,0" />
    </Style>
    <Style Selector="Button.icon-action">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="0" />
    </Style>
  </UserControl.Styles>

  <designer:ToolPageLayout FooterHeight="196">
    <designer:ToolPageLayout.HeaderContent>
      <Border Classes="workspace-panel"
              Padding="20,18">
        <Grid ColumnDefinitions="2.2*,20,Auto"
              ColumnSpacing="0">
          <StackPanel Spacing="4">
            <TextBlock Text="MIGRATIONS"
                       Classes="eyebrow" />
            <TextBlock Text="EF Core 迁移工作台"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusMessage}"
                       Classes="caption-muted"
                       MinHeight="0"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border Grid.Column="2"
                  Padding="18,0,0,0"
                  BorderBrush="{DynamicResource TOrbitBorderBrush}"
                  BorderThickness="1,0,0,0">
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
              <designer:StatusBadge Text="{Binding CurrentDatabaseTypeDisplay, TargetNullValue='未选择数据库'}"
                                    BadgeBackground="{DynamicResource TOrbitSurfaceHoverBrush}"
                                    BadgeForeground="{DynamicResource TOrbitTextSecondaryBrush}" />
              <designer:StatusBadge Text="{Binding MigrationCount, StringFormat='迁移 {0}'}"
                                    BadgeBackground="{DynamicResource TOrbitBadgeInfoBackgroundBrush}"
                                    BadgeForeground="{DynamicResource TOrbitBadgeInfoForegroundBrush}" />
              <designer:StatusBadge Text="{Binding IsBusy, StringFormat='忙碌: {0}'}"
                                    BadgeBackground="{DynamicResource TOrbitBadgeNeutralBackgroundBrush}"
                                    BadgeForeground="{DynamicResource TOrbitBadgeNeutralForegroundBrush}"
                                    IsVisible="{Binding IsBusy}" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </designer:ToolPageLayout.HeaderContent>

    <designer:ToolPageLayout.BodyContent>
      <designer:SplitWorkspace LeftWidth="360"
                               LeftMinWidth="300"
                               RightMinWidth="500">
        <designer:SplitWorkspace.LeftContent>
          <Border Classes="workspace-panel">
            <Grid RowDefinitions="Auto,*,Auto">
              <Grid Margin="20,20,20,16"
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="16">
                <StackPanel Spacing="4">
                  <TextBlock Text="PROFILES"
                             Classes="eyebrow" />
                  <TextBlock Text="连接配置"
                             FontSize="18"
                             FontWeight="SemiBold" />
                  <TextBlock Text="管理数据库配置、项目路径和迁移输出目录。"
                             Classes="caption-muted"
                             MinHeight="0"
                             TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Top">
                  <Button Classes="icon-action"
                          ToolTip.Tip="新增配置"
                          Command="{Binding AddProfileCommand}">
                    <materialIcons:MaterialIcon Kind="Plus"
                                                Width="16"
                                                Height="16" />
                  </Button>
                  <Button Classes="icon-action"
                          ToolTip.Tip="修改配置"
                          Command="{Binding OpenEditProfileCommand}">
                    <materialIcons:MaterialIcon Kind="PencilOutline"
                                                Width="16"
                                                Height="16" />
                  </Button>
                  <Button Classes="icon-action danger"
                          ToolTip.Tip="删除配置"
                          Command="{Binding DeleteProfileCommand}">
                    <materialIcons:MaterialIcon Kind="TrashCanOutline"
                                                Width="16"
                                                Height="16" />
                  </Button>
                  <Button Classes="icon-action"
                          ToolTip.Tip="重新读取配置列表"
                          Command="{Binding RefreshCommand}">
                    <materialIcons:MaterialIcon Kind="Refresh"
                                                Width="16"
                                                Height="16" />
                  </Button>
                </StackPanel>
              </Grid>

              <ScrollViewer Grid.Row="1"
                            Margin="20,0,20,0"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DbProfiles}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:DbConnectionProfile">
                      <Button Classes="profile-item"
                              Classes.selected="{Binding IsSelected}"
                              Command="{Binding $parent[UserControl].((vm:MigrationViewModel)DataContext).SelectProfileCommand}"
                              CommandParameter="{Binding}">
                        <Border Background="Transparent"
                                BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                                Padding="14,12">
                          <StackPanel Spacing="6"
                                      VerticalAlignment="Center">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10"
                                  VerticalAlignment="Center">
                              <TextBlock Text="{Binding EffectiveProfileName}"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         VerticalAlignment="Center"
                                         TextTrimming="CharacterEllipsis" />
                              <StackPanel Grid.Column="1"
                                          Orientation="Horizontal"
                                          Spacing="6"
                                          VerticalAlignment="Center">
                                <designer:StatusBadge Text="{Binding DbTypeTag}"
                                                      BadgeBackground="{DynamicResource TOrbitAccentSubtleBrush}"
                                                      BadgeForeground="{DynamicResource TOrbitAccentSubtleForegroundBrush}" />
                                <designer:StatusBadge Text="{Binding ReadyStatusText}"
                                                      BadgeBackground="{Binding ReadyBadgeBackground}"
                                                      BadgeForeground="{Binding ReadyBadgeForeground}" />
                              </StackPanel>
                            </Grid>

                            <TextBlock Text="{Binding ContextName, StringFormat='DbContext: {0}'}"
                                       Classes="caption-muted"
                                       MinHeight="0"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <Border Grid.Row="2"
                      Margin="20,16,20,20"
                      Background="{DynamicResource TOrbitSurfaceBrush}"
                      BorderBrush="{DynamicResource TOrbitBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                      Padding="12,10">
                <StackPanel Spacing="4">
                  <TextBlock Text="输出目录"
                             Classes="subsection-title" />
                  <TextBlock Text="{Binding OutputDirectory, StringFormat='{}{0}'}"
                             Classes="caption-muted"
                             MinHeight="0"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>
          </Border>
        </designer:SplitWorkspace.LeftContent>

        <designer:SplitWorkspace.RightContent>
          <Border Classes="workspace-panel">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
              <StackPanel Margin="20,20,20,16"
                          Spacing="18">
                <StackPanel Spacing="4">
                  <TextBlock Text="ACTIVE PROFILE"
                             Classes="eyebrow" />
                  <TextBlock Text="当前配置"
                             FontSize="18"
                             FontWeight="SemiBold" />
                  <TextBlock Text="查看属性、选择迁移文件并直接编辑迁移内容。"
                             Classes="caption-muted"
                             MinHeight="0"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="12">
                  <Border Classes="card"
                          Padding="14,12">
                    <StackPanel Spacing="4">
                      <TextBlock Text="数据库类型"
                                 Classes="caption-muted"
                                 MinHeight="0" />
                      <TextBlock Text="{Binding CurrentDatabaseTypeDisplay}"
                                 FontSize="16"
                                 FontWeight="SemiBold" />
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="1"
                          Classes="card"
                          Padding="14,12">
                    <StackPanel Spacing="4">
                      <TextBlock Text="迁移总数"
                                 Classes="caption-muted"
                                 MinHeight="0" />
                      <TextBlock Text="{Binding MigrationCount}"
                                 FontSize="16"
                                 FontWeight="SemiBold" />
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="2"
                          Classes="card"
                          Padding="14,12">
                    <StackPanel Spacing="4">
                      <TextBlock Text="状态"
                                 Classes="caption-muted"
                                 MinHeight="0" />
                      <TextBlock Text="{Binding StatusMessage}"
                                 FontSize="16"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Border>
                </Grid>

                <designer:PropertyGrid ItemsSource="{Binding ActiveProfileProperties}"
                                       LabelColumnWidth="140" />
              </StackPanel>

              <Border Grid.Row="1"
                      Margin="20,0,20,0"
                      BorderBrush="{DynamicResource TOrbitBorderBrush}"
                      BorderThickness="0,1,0,0" />

              <Grid Grid.Row="2"
                    Margin="20,16,20,20"
                    RowDefinitions="Auto"
                    RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <designer:EditorHeader Title="迁移操作">
                    <designer:EditorHeader.ActionContent>
                      <Button Content="查看迁移文件"
                              Command="{Binding OpenMigrationFileCommand}"
                              IsEnabled="{Binding HasSelectedMigration}" />
                    </designer:EditorHeader.ActionContent>
                  </designer:EditorHeader>

                  <StackPanel Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="8"
                              VerticalAlignment="Center">
                    <Border Classes="action-cluster"
                            Padding="8">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="8">
                        <Button Classes="compact-action"
                                Content="新增迁移"
                                Command="{Binding ShowNewPanelCommand}" />
                    <Button Classes="compact-action danger"
                            Content="删除迁移"
                            Command="{Binding RollbackSelectedCommand}"
                            ToolTip.Tip="{Binding RollbackTooltip}"
                            IsEnabled="{Binding CanRollback}" />
                      </StackPanel>
                    </Border>
                    <Button Classes="compact-action accent"
                            Content="执行更新"
                            Command="{Binding ExecuteUpdateCommand}"
                            IsEnabled="{Binding IsIdle}" />
                    <Button Classes="compact-action"
                            Content="取消"
                            Command="{Binding CancelOperationCommand}"
                            IsVisible="{Binding IsBusy}" />
                  </StackPanel>
                </Grid>
              </Grid>
            </Grid>
          </Border>
        </designer:SplitWorkspace.RightContent>
      </designer:SplitWorkspace>
    </designer:ToolPageLayout.BodyContent>

    <designer:ToolPageLayout.FooterContent>
      <designer:LogViewer Title="执行日志"
                          Description="显示最近一次迁移执行与文件操作输出。"
                          Text="{Binding OutputLog}">
        <designer:LogViewer.ActionContent>
          <Button Content="清空日志" Command="{Binding ClearLogCommand}" />
        </designer:LogViewer.ActionContent>
      </designer:LogViewer>
    </designer:ToolPageLayout.FooterContent>
  </designer:ToolPageLayout>
</UserControl>
