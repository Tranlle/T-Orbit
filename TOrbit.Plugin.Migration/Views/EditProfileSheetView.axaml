<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Migration.ViewModels"
             xmlns:models="using:TOrbit.Designer.Models"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:loc="using:TOrbit.Designer.Markup"
             x:Class="TOrbit.Plugin.Migration.Views.EditProfileSheetView"
             x:DataType="vm:MigrationViewModel">
  <UserControl.Styles>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="{DynamicResource SheetSectionTitleFontSize}" />
    </Style>
    <Style Selector="TextBlock.form-label">
      <Setter Property="FontSize" Value="{DynamicResource SheetLabelFontSize}" />
      <Setter Property="MinHeight" Value="20" />
    </Style>
    <Style Selector="TextBlock.caption-muted">
      <Setter Property="FontSize" Value="{DynamicResource SheetCaptionFontSize}" />
      <Setter Property="MinHeight" Value="18" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Height" Value="{DynamicResource SheetControlHeight}" />
      <Setter Property="MinHeight" Value="{DynamicResource SheetControlHeight}" />
      <Setter Property="Padding" Value="14,0" />
    </Style>
    <Style Selector="TextBox, ComboBox">
      <Setter Property="Height" Value="{DynamicResource SheetControlHeight}" />
      <Setter Property="MinHeight" Value="{DynamicResource SheetControlHeight}" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="UseFloatingWatermark" Value="False" />
    </Style>
  </UserControl.Styles>

  <StackPanel Spacing="10">
    <designer:SectionCard Eyebrow="{loc:Loc migration.profile}"
                          Title="{loc:Loc migration.profileIdentity}">
      <designer:SectionCard.Body>
        <Grid ColumnDefinitions="*,10,*"
              RowDefinitions="Auto,Auto"
              RowSpacing="6">
          <designer:FormField Grid.Row="0"
                              Grid.ColumnSpan="3"
                              Label="{loc:Loc migration.domainProjectPath}">
            <designer:FormField.Body>
              <designer:PathPickerField Path="{Binding EditingProjectPath, Mode=TwoWay}"
                                        PlaceholderText="{loc:Loc migration.domainProjectPathPlaceholder}"
                                        BrowseText="{loc:Loc migration.browseProject}"
                                        BrowseCommand="{Binding BrowseProjectPathCommand}" />
            </designer:FormField.Body>
          </designer:FormField>

          <designer:FormField Grid.Row="1"
                              Grid.Column="0"
                              Label="{loc:Loc migration.profileName}">
            <designer:FormField.Body>
              <TextBox Text="{Binding EditingProfile.ProfileName, Mode=TwoWay}"
                       PlaceholderText="{loc:Loc migration.profileNamePlaceholder}" />
            </designer:FormField.Body>
          </designer:FormField>

          <designer:FormField Grid.Row="1"
                              Grid.Column="2"
                              Label="{loc:Loc migration.dbContext}">
            <designer:FormField.Body>
              <TextBox Text="{Binding EditingProfile.ContextName, Mode=TwoWay}"
                       PlaceholderText="{loc:Loc migration.dbContextPlaceholder}" />
            </designer:FormField.Body>
          </designer:FormField>
        </Grid>
      </designer:SectionCard.Body>
    </designer:SectionCard>

    <designer:SectionCard Eyebrow="{loc:Loc migration.connection}"
                          Title="{loc:Loc migration.connectionDetails}">
      <designer:SectionCard.Body>
        <StackPanel Spacing="6">
          <designer:FormField Label="{loc:Loc migration.databaseType}">
            <designer:FormField.Body>
              <ComboBox ItemsSource="{Binding DbTypeOptions}"
                        SelectedItem="{Binding SelectedEditingDbTypeOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="models:DesignerOptionItem">
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </designer:FormField.Body>
          </designer:FormField>

          <designer:FormField Label="{loc:Loc migration.connectionString}">
            <designer:FormField.Body>
              <TextBox Text="{Binding EditingProfile.ConnectionString, Mode=TwoWay}"
                       PlaceholderText="{loc:Loc migration.connectionStringPlaceholder}" />
            </designer:FormField.Body>
          </designer:FormField>
        </StackPanel>
      </designer:SectionCard.Body>
    </designer:SectionCard>
  </StackPanel>
</UserControl>
