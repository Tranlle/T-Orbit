<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:themes="using:Avalonia.Themes.Fluent"
        xmlns:converters="using:Tranbok.Tools.Designer.Converters">
  <themes:FluentTheme />

  <Styles.Resources>
    <x:Boolean x:Key="TrueValue">True</x:Boolean>
    <converters:StringHasValueToBoolConverter x:Key="StringHasValueToBoolConverter" />
    <converters:NullToBoolInverseConverter x:Key="NullToBoolInverseConverter" />
    <converters:BoolInverseConverter x:Key="BoolInverseConverter" />
    <Color x:Key="TranbokColorAccent">#5B8CFF</Color>
    <Color x:Key="TranbokColorAccentHover">#6D99FF</Color>
    <Color x:Key="TranbokColorAccentPressed">#4C7CF6</Color>
    <Color x:Key="TranbokColorSuccess">#2FBF71</Color>
    <Color x:Key="TranbokColorWarning">#E6A23C</Color>
    <Color x:Key="TranbokColorDanger">#EF5B5B</Color>

    <SolidColorBrush x:Key="TranbokAccentBrush" Color="{DynamicResource TranbokColorAccent}" />
    <SolidColorBrush x:Key="TranbokAccentForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TranbokAccentHoverBrush" Color="{DynamicResource TranbokColorAccentHover}" />
    <SolidColorBrush x:Key="TranbokAccentPressedBrush" Color="{DynamicResource TranbokColorAccentPressed}" />
    <SolidColorBrush x:Key="TranbokSuccessBrush" Color="{DynamicResource TranbokColorSuccess}" />
    <SolidColorBrush x:Key="TranbokWarningBrush" Color="{DynamicResource TranbokColorWarning}" />
    <SolidColorBrush x:Key="TranbokDangerBrush" Color="{DynamicResource TranbokColorDanger}" />

    <CornerRadius x:Key="TranbokRadiusSmall">6</CornerRadius>
    <CornerRadius x:Key="TranbokRadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="TranbokRadiusLarge">12</CornerRadius>
    <Thickness x:Key="TranbokPagePadding">24</Thickness>
    <Thickness x:Key="TranbokContentPadding">24</Thickness>
    <Thickness x:Key="TranbokCardPadding">20</Thickness>
    <Thickness x:Key="TranbokControlPadding">12,6</Thickness>
    <Thickness x:Key="TranbokControlMargin">0,0,0,14</Thickness>
    <Thickness x:Key="TranbokSectionSpacing">0,0,0,24</Thickness>
    <Thickness x:Key="TranbokPanelPadding">20</Thickness>
    <x:Double x:Key="TranbokHeaderGap">16</x:Double>
    <x:Double x:Key="TranbokSectionGap">20</x:Double>
    <x:Double x:Key="TranbokItemGap">12</x:Double>
    <x:Double x:Key="TranbokInputHeight">44</x:Double>
    <x:Double x:Key="TranbokInputInnerMinHeight">42</x:Double>
    <x:Double x:Key="TranbokTitleBarHeight">40</x:Double>
    <GridLength x:Key="TranbokNavigationWidth">220</GridLength>
    <Thickness x:Key="TranbokWindowContentPadding">24</Thickness>
    <x:Double x:Key="TranbokButtonHeight">44</x:Double>
    <Thickness x:Key="TranbokButtonPadding">14,7</Thickness>
    <x:Double x:Key="TranbokListItemHeight">44</x:Double>
    <Thickness x:Key="TranbokListItemPadding">10,7</Thickness>

    <SolidColorBrush x:Key="TranbokBackgroundBrush" Color="#0F1115" />
    <SolidColorBrush x:Key="TranbokSurfaceBrush" Color="#151923" />
    <SolidColorBrush x:Key="TranbokSurfaceElevatedBrush" Color="#1B2130" />
    <SolidColorBrush x:Key="TranbokBorderBrush" Color="#293044" />
    <SolidColorBrush x:Key="TranbokTextPrimaryBrush" Color="#F4F7FB" />
    <SolidColorBrush x:Key="TranbokTextSecondaryBrush" Color="#AAB4C4" />
    <SolidColorBrush x:Key="TranbokTextMutedBrush" Color="#738094" />
    <SolidColorBrush x:Key="TranbokBadgeSuccessBackgroundBrush" Color="#1F2D23" />
    <SolidColorBrush x:Key="TranbokBadgeWarningBackgroundBrush" Color="#322818" />
    <SolidColorBrush x:Key="TranbokBadgeDangerBackgroundBrush" Color="#331C22" />

  </Styles.Resources>

  <Style Selector="Window, UserControl, TextBlock, TextBox, ComboBox, ComboBoxItem, CheckBox, RadioButton, Button, DatePicker, TimePicker, CalendarDatePicker, ListBox, ListBoxItem, DataGrid">
    <Setter Property="TextElement.FontFamily" Value="Inter" />
  </Style>

  <StyleInclude Source="avares://Tranbok.Tools.Designer/Themes/Typography.axaml" />
  <StyleInclude Source="avares://Tranbok.Tools.Designer/Themes/Controls.axaml" />
  <StyleInclude Source="avares://Tranbok.Tools.Designer/Themes/Containers.axaml" />
  <StyleInclude Source="avares://Tranbok.Tools.Designer/Themes/Templates.axaml" />
</Styles>
