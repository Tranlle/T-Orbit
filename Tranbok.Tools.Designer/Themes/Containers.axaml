<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="using:Tranbok.Tools.Designer.Controls.Windows">
  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource TranbokBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TranbokTextPrimaryBrush}" />
  </Style>

  <Style Selector="UserControl">
    <Setter Property="Background" Value="{DynamicResource TranbokBackgroundBrush}" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource TranbokSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TranbokBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource TranbokRadiusMedium}" />
    <Setter Property="Padding" Value="{DynamicResource TranbokCardPadding}" />
    <Setter Property="Margin" Value="0,0,0,16" />
  </Style>

  <Style Selector="Border.content-host">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Top" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource TranbokSurfaceElevatedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TranbokBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource TranbokRadiusMedium}" />
  </Style>

  <Style Selector="Border.toolbar">
    <Setter Property="Background" Value="{DynamicResource TranbokSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TranbokBorderBrush}" />
  </Style>

  <Style Selector="windows|DesignerWindowTitleBar">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Button.titlebar-button">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="MinHeight" Value="{DynamicResource TranbokTitleBarHeight}" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Button.titlebar-button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource TranbokSurfaceElevatedBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.titlebar-button.danger:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource TranbokDangerBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.titlebar-button.danger:pointerover">
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="StackPanel.page-section">
    <Setter Property="Spacing" Value="{DynamicResource TranbokSectionGap}" />
    <Setter Property="Margin" Value="0,0,0,20" />
  </Style>

  <Style Selector="StackPanel.page-content">
    <Setter Property="Spacing" Value="{DynamicResource TranbokSectionGap}" />
    <Setter Property="Margin" Value="{DynamicResource TranbokPagePadding}" />
  </Style>

  <Style Selector="Grid.form-grid">
    <Setter Property="ColumnSpacing" Value="20" />
    <Setter Property="RowSpacing" Value="18" />
    <Setter Property="Margin" Value="0,4,0,12" />
  </Style>

  <Style Selector="WrapPanel.action-wrap">
    <Setter Property="ItemSpacing" Value="10" />
    <Setter Property="Margin" Value="0,4,0,0" />
  </Style>

  <Style Selector="StackPanel.content-stack">
    <Setter Property="Spacing" Value="16" />
    <Setter Property="Margin" Value="0,4,0,0" />
  </Style>

  <Style Selector="Border.badge">
    <Setter Property="Background" Value="{DynamicResource TranbokSurfaceElevatedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TranbokBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="10,4" />
  </Style>

  <Style Selector="Border.badge.success">
    <Setter Property="Background" Value="{DynamicResource TranbokBadgeSuccessBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TranbokSuccessBrush}" />
  </Style>

  <Style Selector="Border.badge.warning">
    <Setter Property="Background" Value="{DynamicResource TranbokBadgeWarningBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TranbokWarningBrush}" />
  </Style>

  <Style Selector="Border.badge.danger">
    <Setter Property="Background" Value="{DynamicResource TranbokBadgeDangerBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TranbokDangerBrush}" />
  </Style>
</Styles>
