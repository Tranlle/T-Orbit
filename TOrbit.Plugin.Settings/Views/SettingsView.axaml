<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Settings.ViewModels"
             xmlns:models="using:TOrbit.Designer.Models"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:loc="using:TOrbit.Designer.Markup"
             x:Class="TOrbit.Plugin.Settings.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <UserControl.Styles>
    <Style Selector="Border.settings-section">
      <Setter Property="Padding" Value="0,0,0,20" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.settings-section:last-child">
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Border.settings-hero">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusXLarge}" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.16" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.variable-surface">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusLarge}" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="RenderTransform" Value="translateY(0px)" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.16" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.variable-surface:pointerover">
      <Setter Property="RenderTransform" Value="translateY(-2px)" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderHoverBrush}" />
    </Style>
  </UserControl.Styles>

  <designer:ToolPageLayout HeaderBodyGapHeight="0"
                           BodyFooterGapHeight="0"
                           FooterHeight="0">
    <designer:ToolPageLayout.BodyContent>
      <designer:SplitWorkspace LeftWidth="390"
                               LeftMinWidth="320"
                               RightMinWidth="560">
        <designer:SplitWorkspace.LeftContent>
          <Border Classes="workspace-panel">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="20"
                          Spacing="20">
                <Border Classes="settings-hero">
                  <StackPanel Spacing="6">
                    <TextBlock Text="SETTINGS"
                               Classes="eyebrow" />
                    <TextBlock Text="{loc:Loc settings.title}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc settings.description}"
                               Classes="caption-muted"
                               MinHeight="0"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Classes="settings-section">
                  <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{loc:Loc settings.sections.basic.title}"
                                 Classes="section-title" />
                      <TextBlock Text="{loc:Loc settings.sections.basic.description}"
                                 Classes="caption-muted"
                                 MinHeight="0" />
                    </StackPanel>

                    <designer:FormField Label="{loc:Loc settings.fields.appName}">
                      <designer:FormField.Body>
                        <TextBox Classes="form-control"
                                 Text="{Binding AppName, Mode=TwoWay}"
                                 PlaceholderText="{loc:Loc settings.fields.appNamePlaceholder}" />
                      </designer:FormField.Body>
                    </designer:FormField>

                    <designer:FormField Label="{loc:Loc settings.fields.language}"
                                        Description="{Binding SelectedLanguageOption.Description, TargetNullValue=''}">
                      <designer:FormField.Body>
                        <ComboBox Classes="form-control"
                                  ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Label}" />
                      </designer:FormField.Body>
                    </designer:FormField>

                    <designer:FormField Label="{loc:Loc settings.fields.builtInPalette}"
                                        Description="{Binding SelectedPaletteOption.Description, TargetNullValue=''}">
                      <designer:FormField.Body>
                        <ComboBox Classes="form-control"
                                  ItemsSource="{Binding PaletteOptions}"
                                  SelectedItem="{Binding SelectedPaletteOption, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Label}" />
                      </designer:FormField.Body>
                    </designer:FormField>

                    <designer:FormField Label="{loc:Loc settings.fields.font}"
                                        Description="{Binding SelectedFontOption.Description, TargetNullValue=''}">
                      <designer:FormField.Body>
                        <ComboBox Classes="form-control"
                                  ItemsSource="{Binding FontOptions}"
                                  SelectedItem="{Binding SelectedFontOption, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Label}" />
                      </designer:FormField.Body>
                    </designer:FormField>

                    <Border IsVisible="{Binding IsInterFontWarningVisible}"
                            Background="{DynamicResource TOrbitBadgeWarningBackgroundBrush}"
                            BorderBrush="{DynamicResource TOrbitBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                            Padding="12,10">
                      <TextBlock Text="{Binding FontWarningMessage}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TOrbitBadgeWarningForegroundBrush}"
                                 TextWrapping="Wrap" />
                    </Border>

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="16"
                          VerticalAlignment="Center">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{loc:Loc settings.fields.closeBehavior}"
                                   Classes="subsection-title" />
                        <TextBlock Text="{loc:Loc settings.fields.closeBehaviorDescription}"
                                   Classes="caption-muted"
                                   MinHeight="0"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                      <ToggleSwitch Grid.Column="1"
                                    IsChecked="{Binding MinimizeToTrayOnClose, Mode=TwoWay}"
                                    OnContent="{loc:Loc settings.options.tray}"
                                    OffContent="{loc:Loc settings.options.exit}" />
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Classes="settings-section">
                  <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{loc:Loc settings.sections.advancedTheme.title}"
                                 Classes="section-title" />
                      <TextBlock Text="{loc:Loc settings.sections.advancedTheme.description}"
                                 Classes="caption-muted"
                                 MinHeight="0" />
                    </StackPanel>

                    <CheckBox Content="{loc:Loc settings.fields.advancedThemeVisible}"
                              IsChecked="{Binding ShowAdvancedThemeSettings, Mode=TwoWay}" />

                    <StackPanel Spacing="14"
                                IsVisible="{Binding ShowAdvancedThemeSettings}">
                      <designer:FormField Label="{loc:Loc settings.sections.advancedTheme.palette}"
                                          Description="{Binding SelectedAdvancedPaletteOption.Description, TargetNullValue=''}">
                        <designer:FormField.Body>
                          <ComboBox Classes="form-control"
                                    ItemsSource="{Binding AdvancedPaletteOptions}"
                                    SelectedItem="{Binding SelectedAdvancedPaletteOption, Mode=TwoWay}"
                                    DisplayMemberBinding="{Binding Label}" />
                        </designer:FormField.Body>
                      </designer:FormField>

                      <designer:FormField Label="{loc:Loc settings.sections.advancedTheme.directory}">
                        <designer:FormField.Body>
                          <TextBox Classes="form-control"
                                   Text="{Binding CustomThemeDirectory, Mode=TwoWay}" />
                        </designer:FormField.Body>
                      </designer:FormField>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <Border Classes="settings-section">
                  <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{loc:Loc settings.workspace.title}"
                                 Classes="section-title" />
                      <TextBlock Text="{loc:Loc settings.workspace.description}"
                                 Classes="caption-muted"
                                 MinHeight="0" />
                    </StackPanel>

                    <designer:FormField Label="{loc:Loc settings.workspace.root}">
                      <designer:FormField.Body>
                        <TextBox Classes="form-control"
                                 Text="{Binding WorkspaceRoot, Mode=TwoWay}" />
                      </designer:FormField.Body>
                    </designer:FormField>

                    <CheckBox Content="{loc:Loc settings.workspace.useForMigration}"
                              IsChecked="{Binding UseWorkspaceForMigrations, Mode=TwoWay}" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </designer:SplitWorkspace.LeftContent>

        <designer:SplitWorkspace.RightContent>
          <Border Classes="workspace-panel">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="20"
                          Spacing="18">
                <Border Classes="settings-hero">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{loc:Loc settings.variables.eyebrow}"
                               Classes="eyebrow" />
                    <TextBlock Text="{loc:Loc settings.variables.title}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc settings.variables.description}"
                               Classes="caption-muted"
                               MinHeight="0"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="16">
                  <TextBlock Text="{Binding PluginVariableSummary}"
                             Classes="caption-muted"
                             MinHeight="0"
                             VerticalAlignment="Center"
                             TextWrapping="Wrap" />
                  <Button Grid.Column="1"
                          Command="{Binding ShowAddVariableFormCommand}"
                          IsVisible="{Binding !ShowAddVariableForm}"
                          Classes="accent"
                          Content="{loc:Loc settings.variables.add}"
                          VerticalAlignment="Center" />
                </Grid>

                <Border IsVisible="{Binding ShowAddVariableForm}"
                        Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                        BorderBrush="{DynamicResource TOrbitAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource TOrbitRadiusLarge}"
                        Padding="18">
                  <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                      <TextBlock Classes="section-title"
                                 Text="{loc:Loc settings.variables.createTitle}" />
                      <TextBlock Classes="caption-muted"
                                 MinHeight="0"
                                 Text="{loc:Loc settings.variables.createDescription}" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,16,*">
                      <designer:FormField Grid.Column="0" Label="{loc:Loc settings.variables.plugin}">
                        <designer:FormField.Body>
                          <ComboBox Classes="form-control"
                                    ItemsSource="{Binding PluginOptions}"
                                    SelectedItem="{Binding AddFormSelectedPlugin, Mode=TwoWay}"
                                    DisplayMemberBinding="{Binding Label}" />
                        </designer:FormField.Body>
                      </designer:FormField>

                      <designer:FormField Grid.Column="2" Label="{loc:Loc settings.variables.key}">
                        <designer:FormField.Body>
                          <TextBox Classes="form-control"
                                   Text="{Binding AddFormKey, Mode=TwoWay}"
                                   PlaceholderText="{loc:Loc settings.variables.keyPlaceholder}" />
                        </designer:FormField.Body>
                      </designer:FormField>
                    </Grid>

                    <StackPanel Spacing="6"
                                IsVisible="{Binding HasAddFormKeyHints}">
                      <TextBlock Classes="caption-muted"
                                 MinHeight="0"
                                 Text="{loc:Loc settings.variables.keyHints}" />
                      <ItemsControl ItemsSource="{Binding AddFormKeyHints}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="models:DesignerOptionItem">
                            <Button Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).FillKeyFromHintCommand}"
                                    CommandParameter="{Binding}"
                                    Height="28"
                                    MinHeight="28"
                                    Padding="10,0"
                                    Margin="0,0,8,8"
                                    FontSize="11"
                                    ToolTip.Tip="{Binding Description}">
                              <TextBlock Text="{Binding Label}" FontSize="11" />
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>

                    <designer:FormField Label="{loc:Loc settings.variables.value}">
                      <designer:FormField.Body>
                        <TextBox Classes="form-control"
                                 Text="{Binding AddFormValue, Mode=TwoWay}"
                                 PlaceholderText="{loc:Loc settings.variables.valuePlaceholder}" />
                      </designer:FormField.Body>
                    </designer:FormField>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8">
                      <Button Command="{Binding CancelAddVariableCommand}" Content="{loc:Loc dialog.cancel}" />
                      <Button Command="{Binding AddVariableCommand}" Classes="accent" Content="{loc:Loc settings.header.actions.save}" />
                    </StackPanel>
                  </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding PluginVariableGroups}"
                              IsVisible="{Binding HasPluginVariables}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PluginVariableGroupViewModel">
                      <Border Classes="variable-surface"
                              Margin="0,0,0,14">
                        <StackPanel Spacing="14">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="12">
                            <StackPanel Spacing="6">
                              <StackPanel Orientation="Horizontal"
                                          Spacing="8">
                                <TextBlock Text="{Binding PluginName}"
                                           Classes="section-title"
                                           VerticalAlignment="Center" />
                                <Border Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                                        BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="999"
                                        Padding="8,3">
                                  <TextBlock Text="{Binding Count}"
                                             FontSize="11"
                                             Foreground="{DynamicResource TOrbitTextMutedBrush}" />
                                </Border>
                              </StackPanel>

                              <TextBlock Text="{Binding CapabilitySummary}"
                                         Classes="caption-muted"
                                         MinHeight="0"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                          </Grid>

                          <ItemsControl ItemsSource="{Binding CapabilityTags}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                                        BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="999"
                                        Padding="8,3"
                                        Margin="0,0,8,8">
                                  <TextBlock Text="{Binding .}"
                                             FontSize="11"
                                             Foreground="{DynamicResource TOrbitTextMutedBrush}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>

                          <Grid ColumnDefinitions="*,220,32"
                                ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Classes="field-label" Text="{loc:Loc settings.variables.key}" />
                            <TextBlock Grid.Column="1" Classes="field-label" Text="{loc:Loc settings.variables.value}" />
                          </Grid>

                          <ItemsControl ItemsSource="{Binding Variables}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:PluginVariableItemViewModel">
                                <Border BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="0,12,0,0">
                                  <Grid ColumnDefinitions="*,220,32"
                                        ColumnSpacing="10"
                                        VerticalAlignment="Center">
                                    <StackPanel Grid.Column="0"
                                                Spacing="4"
                                                VerticalAlignment="Center">
                                      <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding Key}"
                                                   FontFamily="{DynamicResource TOrbitMonoFontFamily}"
                                                   FontSize="12" />
                                        <Border IsVisible="{Binding IsEncrypted}"
                                                Background="{DynamicResource TOrbitBadgeInfoBackgroundBrush}"
                                                CornerRadius="4"
                                                Padding="5,1"
                                                VerticalAlignment="Center">
                                          <TextBlock Text="{loc:Loc settings.variables.encrypted}"
                                                     FontSize="10"
                                                     Foreground="{DynamicResource TOrbitBadgeInfoForegroundBrush}" />
                                        </Border>
                                      </StackPanel>

                                      <TextBlock Text="{Binding Description}"
                                                 Classes="caption-muted"
                                                 MinHeight="0"
                                                 IsVisible="{Binding IsFromMetadata}"
                                                 TextWrapping="Wrap" />
                                    </StackPanel>

                                    <TextBox Grid.Column="1"
                                             Classes="form-control"
                                             Text="{Binding Value, Mode=TwoWay}"
                                             PasswordChar="{Binding PasswordChar}"
                                             Height="32"
                                             MinHeight="32"
                                             VerticalAlignment="Center" />

                                    <Button Grid.Column="2"
                                            Command="{Binding DeleteCommand}"
                                            Classes="danger"
                                            Width="32"
                                            Height="32"
                                            MinHeight="32"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            ToolTip.Tip="{loc:Loc runtime.delete}"
                                            Content="×"
                                            FontSize="14" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Classes="caption-muted"
                           IsVisible="{Binding !HasPluginVariables}"
                           Text="{loc:Loc settings.sections.variables.empty}" />
              </StackPanel>
            </ScrollViewer>
          </Border>
        </designer:SplitWorkspace.RightContent>
      </designer:SplitWorkspace>
    </designer:ToolPageLayout.BodyContent>
  </designer:ToolPageLayout>
</UserControl>
