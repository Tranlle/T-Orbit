<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Home.ViewModels"
             x:Class="TOrbit.Plugin.Home.Views.HomeView"
             x:DataType="vm:HomeViewModel">

  <Border Classes="workspace-panel">
    <ScrollViewer Padding="20"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0">
        <StackPanel IsVisible="{Binding !HasReports}"
                    Spacing="8">
          <TextBlock Text="当前没有可展示的报表。"
                     Classes="section-title" />
          <TextBlock Text="后续插件实现首页报表接口后，会自动出现在这里。"
                     Classes="caption-muted"
                     MinHeight="0"
                     TextWrapping="Wrap" />
        </StackPanel>

        <ItemsControl ItemsSource="{Binding ReportGroups}"
                      IsVisible="{Binding HasReports}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:HomeReportGroupViewModel">
              <StackPanel Spacing="12"
                          Margin="0,0,0,18">
                <TextBlock Text="{Binding Category}"
                           Classes="section-title" />

                <ItemsControl ItemsSource="{Binding Reports}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal"
                                 ItemWidth="440" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:HomeReportItemViewModel">
                      <Border Classes="card"
                              Width="424"
                              MinHeight="260"
                              Margin="0,0,16,16"
                              Padding="18">
                        <Grid RowDefinitions="Auto,Auto,*"
                              RowSpacing="14">
                          <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Definition.Title}"
                                       Classes="section-title" />
                            <TextBlock Text="{Binding Definition.Description}"
                                       Classes="caption-muted"
                                       MinHeight="0"
                                       MaxLines="2"
                                       TextWrapping="Wrap" />
                          </StackPanel>

                          <Border Grid.Row="1"
                                  BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                  BorderThickness="0,1,0,0" />

                          <Grid Grid.Row="2">
                            <ContentControl Content="{Binding Content}"
                                            IsVisible="{Binding HasContent}" />

                            <StackPanel IsVisible="{Binding IsPending}"
                                        Spacing="10"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                              <ProgressBar Width="180"
                                           IsIndeterminate="True" />
                              <TextBlock Text="报表准备中..."
                                         Classes="caption-muted"
                                         HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel IsVisible="{Binding IsLoading}"
                                        Spacing="10"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                              <ProgressBar Width="180"
                                           IsIndeterminate="True" />
                              <TextBlock Text="正在加载报表..."
                                         Classes="caption-muted"
                                         HorizontalAlignment="Center" />
                            </StackPanel>

                            <Border IsVisible="{Binding HasError}"
                                    Background="{DynamicResource TOrbitBadgeDangerBackgroundBrush}"
                                    BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                                    Padding="14,12"
                                    VerticalAlignment="Center">
                              <StackPanel Spacing="8">
                                <TextBlock Text="报表加载失败"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TOrbitBadgeDangerForegroundBrush}" />
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="{DynamicResource TOrbitBadgeDangerForegroundBrush}"
                                           TextWrapping="Wrap" />
                                <Button Content="重新加载"
                                        Command="{Binding LoadCommand}"
                                        HorizontalAlignment="Left" />
                              </StackPanel>
                            </Border>
                          </Grid>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Height="24"
                Background="Transparent" />
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
