<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Home.ViewModels"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:loc="using:TOrbit.Designer.Markup"
             x:Class="TOrbit.Plugin.Home.Views.HomeView"
             x:DataType="vm:HomeViewModel">

  <UserControl.Styles>
    <Style Selector="Border.report-surface">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusLarge}" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="RenderTransform" Value="translateY(0px)" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.16" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.report-surface:pointerover">
      <Setter Property="RenderTransform" Value="translateY(-3px)" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderHoverBrush}" />
    </Style>
  </UserControl.Styles>

  <Border Background="Transparent">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="18">
        <designer:EmptyState IsVisible="{Binding !HasReports}"
                             Title="{loc:Loc home.empty.title}"
                             Description="{loc:Loc home.empty.description}" />

        <ItemsControl ItemsSource="{Binding ReportGroups}"
                      IsVisible="{Binding HasReports}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:HomeReportGroupViewModel">
              <StackPanel Spacing="14"
                          Margin="0,0,0,12">
                <ItemsControl ItemsSource="{Binding Reports}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal"
                                 ItemWidth="520" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:HomeReportItemViewModel">
                      <Border Classes="report-surface"
                              Width="500"
                              MinHeight="280"
                              Margin="0,0,16,16">
                        <Grid RowDefinitions="Auto,Auto,*"
                              RowSpacing="14">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="16">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding Definition.Title}"
                                         Classes="section-title" />
                              <TextBlock Text="{Binding Definition.Description}"
                                         Classes="caption-muted"
                                         MinHeight="0"
                                         MaxLines="2"
                                         TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                                    BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="10,4"
                                    VerticalAlignment="Top">
                              <TextBlock Text="{loc:Loc home.report.badge}"
                                         FontSize="11"
                                         Foreground="{DynamicResource TOrbitTextMutedBrush}" />
                            </Border>
                          </Grid>

                          <Border Grid.Row="1"
                                  BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                  BorderThickness="0,1,0,0" />

                          <Grid Grid.Row="2">
                            <ContentControl Content="{Binding Content}"
                                            IsVisible="{Binding HasContent}" />

                            <StackPanel IsVisible="{Binding IsPending}"
                                        Spacing="10"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                              <ProgressBar Width="180"
                                           IsIndeterminate="True" />
                              <TextBlock Text="{loc:Loc home.report.preparing}"
                                         Classes="caption-muted"
                                         HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel IsVisible="{Binding IsLoading}"
                                        Spacing="10"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                              <ProgressBar Width="180"
                                           IsIndeterminate="True" />
                              <TextBlock Text="{loc:Loc home.report.loading}"
                                         Classes="caption-muted"
                                         HorizontalAlignment="Center" />
                            </StackPanel>

                            <Border IsVisible="{Binding HasError}"
                                    Background="{DynamicResource TOrbitBadgeDangerBackgroundBrush}"
                                    BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                                    Padding="14,12"
                                    VerticalAlignment="Center">
                              <StackPanel Spacing="8">
                                <TextBlock Text="{loc:Loc home.report.failed}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TOrbitBadgeDangerForegroundBrush}" />
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="{DynamicResource TOrbitBadgeDangerForegroundBrush}"
                                           TextWrapping="Wrap" />
                                <Button Content="{loc:Loc home.report.retry}"
                                        Command="{Binding LoadCommand}"
                                        HorizontalAlignment="Left" />
                              </StackPanel>
                            </Border>
                          </Grid>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
