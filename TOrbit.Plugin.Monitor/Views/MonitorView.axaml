<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Monitor.ViewModels"
             xmlns:models="using:TOrbit.Core.Models"
             xmlns:designer="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Plugin.Monitor.Views.MonitorView"
             x:DataType="vm:MonitorViewModel">

  <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
    <Border Grid.Row="0"
            Classes="workspace-panel"
            Padding="20,18">
      <Grid ColumnDefinitions="2.2*,18,Auto,Auto,Auto,Auto"
            ColumnSpacing="0">
        <StackPanel Spacing="4"
                    VerticalAlignment="Center">
          <TextBlock Text="Runtime Control"
                     Classes="eyebrow" />
          <TextBlock Text="监控插件运行、故障和宿主诊断流。"
                     FontSize="18"
                     FontWeight="SemiBold" />
          <TextBlock Text="左侧清单用于定位插件，右侧聚焦当前实例的状态与可执行操作。"
                     Classes="caption-muted"
                     MinHeight="0" />
        </StackPanel>

        <Border Grid.Column="2"
                Padding="16,0,0,0"
                BorderBrush="{DynamicResource TOrbitBorderBrush}"
                BorderThickness="1,0,0,0">
          <StackPanel Spacing="2"
                      VerticalAlignment="Center">
            <TextBlock Text="总插件"
                       Classes="caption-muted"
                       MinHeight="0" />
            <TextBlock Text="{Binding TotalCount}"
                       FontSize="24"
                       FontWeight="SemiBold" />
          </StackPanel>
        </Border>

        <Border Grid.Column="3"
                Padding="16,0,0,0"
                BorderBrush="{DynamicResource TOrbitBorderBrush}"
                BorderThickness="1,0,0,0">
          <StackPanel Spacing="2"
                      VerticalAlignment="Center">
            <TextBlock Text="运行中"
                       Classes="caption-muted"
                       MinHeight="0" />
            <TextBlock Text="{Binding RunningCount}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TOrbitBadgeSuccessForegroundBrush}" />
          </StackPanel>
        </Border>

        <Border Grid.Column="4"
                Padding="16,0,0,0"
                BorderBrush="{DynamicResource TOrbitBorderBrush}"
                BorderThickness="1,0,0,0">
          <StackPanel Spacing="2"
                      VerticalAlignment="Center">
            <TextBlock Text="故障"
                       Classes="caption-muted"
                       MinHeight="0" />
            <TextBlock Text="{Binding FaultedCount}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TOrbitBadgeDangerForegroundBrush}" />
          </StackPanel>
        </Border>

        <Border Grid.Column="5"
                Padding="16,0,0,0"
                BorderBrush="{DynamicResource TOrbitBorderBrush}"
                BorderThickness="1,0,0,0">
          <StackPanel Spacing="2"
                      VerticalAlignment="Center">
            <TextBlock Text="错误诊断"
                       Classes="caption-muted"
                       MinHeight="0" />
            <TextBlock Text="{Binding ErrorDiagnosticCount}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TOrbitAccentBrush}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="360,20,*">
      <Border Grid.Column="0" Classes="workspace-panel">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0"
                  Padding="18,16"
                  BorderBrush="{DynamicResource TOrbitBorderBrush}"
                  BorderThickness="0,0,0,1">
            <StackPanel Spacing="2">
              <TextBlock Text="插件清单"
                         Classes="section-title" />
              <TextBlock Text="{Binding TotalCount, StringFormat='共 {0} 个插件'}"
                         Classes="caption-muted"
                         MinHeight="0" />
            </StackPanel>
          </Border>

          <ListBox Grid.Row="1"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="8"
                   ItemsSource="{Binding MonitorItems}"
                   SelectedItem="{Binding SelectedMonitorItem, Mode=TwoWay}">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,1,0,1" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Height" Value="NaN" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusSmall}" />
              </Style>
              <Style Selector="ListBoxItem /template/ ContentPresenter">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
              </Style>
              <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceHoverBrush}" />
              </Style>
              <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource TOrbitAccentSubtleBrush}" />
              </Style>
              <Style Selector="ListBoxItem:selected TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TOrbitAccentSubtleForegroundBrush}" />
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:PluginMonitorItemViewModel">
                <Border Padding="14,12" CornerRadius="{DynamicResource TOrbitRadiusMedium}">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                      <Border Grid.Column="1"
                              Background="{Binding StateBadgeBackground}"
                              CornerRadius="999"
                              Padding="8,3"
                              VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                          <Ellipse Width="5" Height="5" VerticalAlignment="Center" Fill="{Binding StateDotBrush}" />
                          <TextBlock Text="{Binding StateStatusLabel}"
                                     Foreground="{Binding StateBadgeForeground}"
                                     FontSize="11"
                                     FontWeight="Medium"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                      </Border>
                    </Grid>

                    <TextBlock Text="{Binding Description}"
                               Classes="caption-muted"
                               MinHeight="0"
                               MaxLines="2"
                               TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Background="{DynamicResource TOrbitSurfaceHoverBrush}" CornerRadius="999" Padding="8,3">
                        <TextBlock Text="{Binding KindTagLabel}" FontSize="11" Foreground="{DynamicResource TOrbitTextMutedBrush}" />
                      </Border>
                      <Border Background="{DynamicResource TOrbitSurfaceHoverBrush}" CornerRadius="999" Padding="8,3">
                        <TextBlock Text="{Binding SourceLabel}" FontSize="11" Foreground="{DynamicResource TOrbitTextMutedBrush}" />
                      </Border>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="2" Classes="workspace-panel">
        <Grid>
          <StackPanel IsVisible="{Binding !HasSelectedMonitorItem}"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="10"
                      Margin="32">
            <TextBlock Text="选择一个插件"
                       Classes="section-title"
                       HorizontalAlignment="Center" />
            <TextBlock Text="右侧会显示运行状态、能力标签、故障信息以及当前可执行操作。"
                       Classes="caption-muted"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="280" />
          </StackPanel>

          <ContentControl Content="{Binding SelectedMonitorItem}" IsVisible="{Binding HasSelectedMonitorItem}">
            <ContentControl.ContentTemplate>
              <DataTemplate x:DataType="vm:PluginMonitorItemViewModel">
                <Grid RowDefinitions="Auto,*,Auto">
                  <Border Grid.Row="0"
                          Padding="22,18"
                          BorderBrush="{DynamicResource TOrbitBorderBrush}"
                          BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                      <StackPanel Spacing="3">
                        <TextBlock Text="{Binding Id}"
                                   Classes="eyebrow" />
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Description}" Classes="caption-muted" TextWrapping="Wrap" />
                      </StackPanel>
                      <designer:StatusBadge Grid.Column="1"
                                            VerticalAlignment="Top"
                                            Text="{Binding StateLabel}"
                                            BadgeBackground="{Binding StateBadgeBackground}"
                                            BadgeForeground="{Binding StateBadgeForeground}" />
                    </Grid>
                  </Border>

                  <ScrollViewer Grid.Row="1"
                                Padding="22,18"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18">
                      <Grid ColumnDefinitions="*,*,*"
                            ColumnSpacing="12">
                        <Border Classes="card"
                                Padding="14,12">
                          <StackPanel Spacing="4">
                            <TextBlock Text="版本"
                                       Classes="caption-muted"
                                       MinHeight="0" />
                            <TextBlock Text="{Binding Version}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                          </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Classes="card"
                                Padding="14,12">
                          <StackPanel Spacing="4">
                            <TextBlock Text="类型"
                                       Classes="caption-muted"
                                       MinHeight="0" />
                            <TextBlock Text="{Binding KindLabel}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                          </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Classes="card"
                                Padding="14,12">
                          <StackPanel Spacing="4">
                            <TextBlock Text="最近更新"
                                       Classes="caption-muted"
                                       MinHeight="0" />
                            <TextBlock Text="{Binding StateChangedAtText}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                          </StackPanel>
                        </Border>
                      </Grid>

                      <Grid ColumnDefinitions="108,*"
                            RowDefinitions="Auto,Auto"
                            RowSpacing="10"
                            ColumnSpacing="14">
                        <TextBlock Text="来源"
                                   Classes="field-label" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SourceLabel}"
                                   Classes="field-value" />

                        <TextBlock Grid.Row="1"
                                   Text="启用状态"
                                   Classes="field-label" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding EnabledLabel}"
                                   Classes="field-value" />
                      </Grid>

                      <StackPanel Spacing="8"
                                  IsVisible="{Binding HasCapabilities}">
                        <TextBlock Text="能力标签"
                                   Classes="section-title" />
                        <ItemsControl ItemsSource="{Binding CapabilityTags}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                                      BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                      BorderThickness="1"
                                      CornerRadius="999"
                                      Padding="10,4"
                                      Margin="0,0,8,8">
                                <TextBlock Text="{Binding .}" FontSize="11" Foreground="{DynamicResource TOrbitTextMutedBrush}" />
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>

                      <Border BorderBrush="{DynamicResource TOrbitBorderBrush}" BorderThickness="0,1,0,0" />

                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" VerticalAlignment="Center">
                        <StackPanel Spacing="4">
                          <TextBlock Text="运行开关"
                                     Classes="section-title" />
                          <TextBlock Text="关闭后停止该插件，重新启用时会根据当前状态尝试恢复运行。"
                                     Classes="caption-muted"
                                     MinHeight="0"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding CanToggleEnabled}" />
                      </Grid>

                      <Border BorderBrush="{DynamicResource TOrbitBorderBrush}" BorderThickness="0,1,0,0" />

                      <StackPanel Spacing="8">
                        <TextBlock Text="最近错误"
                                   Classes="section-title" />
                        <Border IsVisible="{Binding HasError}"
                                Background="{DynamicResource TOrbitBadgeDangerBackgroundBrush}"
                                BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                                Padding="14,12">
                          <TextBlock Text="{Binding LastErrorMessage}"
                                     FontSize="12"
                                     Foreground="{DynamicResource TOrbitBadgeDangerForegroundBrush}"
                                     TextWrapping="Wrap" />
                        </Border>
                        <TextBlock Text="当前没有错误记录。"
                                   Classes="caption-muted"
                                   IsVisible="{Binding !HasError}" />
                      </StackPanel>
                    </StackPanel>
                  </ScrollViewer>

                  <Border Grid.Row="2"
                          Padding="22,16"
                          BorderBrush="{DynamicResource TOrbitBorderBrush}"
                          BorderThickness="0,1,0,0">
                    <Button Content="重启插件"
                            Classes="accent"
                            Command="{Binding RestartCommand}"
                            IsEnabled="{Binding CanRestart}"
                            HorizontalAlignment="Right" />
                  </Border>
                </Grid>
              </DataTemplate>
            </ContentControl.ContentTemplate>
          </ContentControl>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2"
            Classes="workspace-panel">
      <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Padding="20,16"
                BorderBrush="{DynamicResource TOrbitBorderBrush}"
                BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="2">
              <TextBlock Text="应用诊断"
                         Classes="section-title" />
              <TextBlock Text="这里保留宿主启动、插件发现、迁移和关闭阶段的关键异常。"
                         Classes="caption-muted"
                         MinHeight="0" />
            </StackPanel>
            <Border Grid.Column="1"
                    Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                    CornerRadius="999"
                    Padding="10,4"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding DiagnosticCount}"
                         Foreground="{DynamicResource TOrbitTextMutedBrush}" />
            </Border>
          </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="20"
                    Spacing="8"
                    IsVisible="{Binding !HasDiagnostics}">
          <TextBlock Text="当前没有诊断记录。"
                     Classes="caption-muted" />
        </StackPanel>

        <ItemsControl Grid.Row="1"
                      Margin="20"
                      ItemsSource="{Binding Diagnostics}"
                      IsVisible="{Binding HasDiagnostics}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:AppDiagnosticEntry">
              <Border Background="{DynamicResource TOrbitSurfaceBrush}"
                      BorderBrush="{DynamicResource TOrbitBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                      Padding="14,12"
                      Margin="0,0,0,12">
                <StackPanel Spacing="4">
                  <Grid ColumnDefinitions="Auto,8,*,Auto" VerticalAlignment="Center">
                    <Border Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                            CornerRadius="999"
                            Padding="8,3">
                      <TextBlock Text="{Binding Severity}" FontSize="11" />
                    </Border>
                    <TextBlock Grid.Column="2"
                               Text="{Binding Source}"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                               Classes="caption-muted" />
                  </Grid>
                  <TextBlock Text="{Binding Message}"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding Exception.Message}"
                             TextWrapping="Wrap"
                             Classes="caption-muted"
                             IsVisible="{Binding Exception}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>
  </Grid>
</UserControl>
