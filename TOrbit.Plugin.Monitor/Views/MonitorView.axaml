<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Monitor.ViewModels"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:converters="using:TOrbit.Plugin.Monitor.Converters"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="TOrbit.Plugin.Monitor.Views.MonitorView"
             x:DataType="vm:MonitorViewModel">

  <UserControl.Resources>
    <converters:IconNameToMaterialIconKindConverter x:Key="IconNameConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Border.monitor-hero">
      <Setter Property="Background" Value="#101B24" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusXLarge}" />
      <Setter Property="Padding" Value="24" />
    </Style>

    <Style Selector="Border.monitor-focus">
      <Setter Property="Background" Value="#0F1B25" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitAccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusLarge}" />
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="Border.monitor-row">
      <Setter Property="Background" Value="#101923" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusLarge}" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="RenderTransform" Value="translateY(0px)" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.16" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.monitor-row:pointerover">
      <Setter Property="RenderTransform" Value="translateY(-2px)" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderHoverBrush}" />
    </Style>

    <Style Selector="Border.monitor-tag">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.16" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.monitor-icon">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="RenderTransform" Value="scale(1)" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.14" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.14" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.14" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.monitor-icon:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.06)" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderHoverBrush}" />
    </Style>
  </UserControl.Styles>

  <Border Background="Transparent">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="18">
        <ItemsControl ItemsSource="{Binding MonitorItems}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:PluginMonitorItemViewModel">
              <Border Classes="monitor-row"
                      Margin="0,0,0,12"
                      Tapped="MonitorCard_OnTapped"
                      DoubleTapped="MonitorCard_OnDoubleTapped">
                <Grid ColumnDefinitions="Auto,2.1*,1.4*,Auto"
                      ColumnSpacing="18">
                  <Border Width="48"
                          Height="48"
                          Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                          CornerRadius="14"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top">
                    <materialIcons:MaterialIcon Kind="{Binding Icon, Converter={StaticResource IconNameConverter}}"
                                                Width="24"
                                                Height="24"
                                                Foreground="{DynamicResource TOrbitTextPrimaryBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                  </Border>

                  <StackPanel Grid.Column="1"
                              Spacing="8">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="16"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding Id}"
                                 Classes="caption-muted"
                                 MinHeight="0"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <TextBlock Text="{Binding Description}"
                               Classes="caption-muted"
                               MinHeight="0"
                               MaxLines="2"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <StackPanel Grid.Column="2"
                              Spacing="10">
                    <TextBlock Text="Capabilities"
                               Classes="caption-muted"
                               MinHeight="0" />
                    <designer:BadgeFlow ItemsSource="{Binding CardTags}">
                      <designer:BadgeFlow.ItemTemplate>
                        <DataTemplate x:DataType="vm:PluginMonitorTagViewModel">
                          <Border Classes="monitor-tag"
                                  Background="{Binding Background}"
                                  CornerRadius="999"
                                  Padding="10,4"
                                  MinHeight="24"
                                  VerticalAlignment="Center">
                            <TextBlock Text="{Binding Text}"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{Binding Foreground}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       LineHeight="14" />
                          </Border>
                        </DataTemplate>
                      </designer:BadgeFlow.ItemTemplate>
                    </designer:BadgeFlow>

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                      <StackPanel Spacing="2">
                        <TextBlock Text="Last change"
                                   Classes="caption-muted"
                                   MinHeight="0" />
                        <TextBlock Text="{Binding StateChangedAtText}"
                                   FontSize="12" />
                      </StackPanel>

                      <StackPanel Grid.Column="1"
                                  Spacing="6"
                                  HorizontalAlignment="Right">
                        <TextBlock Text="Enabled"
                                   Classes="caption-muted"
                                   MinHeight="0"
                                   HorizontalAlignment="Right" />
                        <ToggleSwitch IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding CanToggleEnabled}"
                                      OffContent=""
                                      OnContent="" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>

                  <StackPanel Grid.Column="3"
                              Orientation="Horizontal"
                              Spacing="6"
                              VerticalAlignment="Top">
                    <Button Classes="monitor-icon"
                            Command="{Binding RestartCommand}"
                            IsEnabled="{Binding CanRestart}"
                            ToolTip.Tip="Restart plugin">
                      <materialIcons:MaterialIcon Kind="Refresh"
                                                  Width="16"
                                                  Height="16" />
                    </Button>
                    <Button Classes="monitor-icon"
                            Command="{Binding StopCommand}"
                            IsEnabled="{Binding CanStop}"
                            ToolTip.Tip="Stop plugin">
                      <materialIcons:MaterialIcon Kind="Power"
                                                  Width="16"
                                                  Height="16" />
                    </Button>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
