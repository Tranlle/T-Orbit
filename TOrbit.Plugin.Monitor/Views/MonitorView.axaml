<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Monitor.ViewModels"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:converters="using:TOrbit.Plugin.Monitor.Converters"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="TOrbit.Plugin.Monitor.Views.MonitorView"
             x:DataType="vm:MonitorViewModel">

  <UserControl.Resources>
    <converters:IconNameToMaterialIconKindConverter x:Key="IconNameConverter" />
  </UserControl.Resources>

  <Border Classes="workspace-panel">
    <ScrollViewer Padding="20,20,20,28"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0">
        <ItemsControl ItemsSource="{Binding MonitorItems}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal"
                         ItemWidth="352" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:PluginMonitorItemViewModel">
              <Border Classes="card"
                      Width="336"
                      Height="272"
                      Margin="0,0,16,16"
                      Padding="18"
                      CornerRadius="{DynamicResource TOrbitRadiusLarge}"
                      DoubleTapped="MonitorCard_OnDoubleTapped">
                <Grid RowDefinitions="Auto,Auto,*,Auto"
                      RowSpacing="14">
                  <Grid ColumnDefinitions="Auto,*,Auto"
                        ColumnSpacing="12">
                    <Border Width="42"
                            Height="42"
                            Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                            CornerRadius="12"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                      <materialIcons:MaterialIcon Kind="{Binding Icon, Converter={StaticResource IconNameConverter}}"
                                                  Width="22"
                                                  Height="22"
                                                  Foreground="{DynamicResource TOrbitTextPrimaryBrush}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Spacing="2">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="15"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding Id}"
                                 Classes="caption-muted"
                                 MinHeight="0"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Top">
                      <Button Width="32"
                              Height="32"
                              Padding="0"
                              CornerRadius="999"
                              Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                              BorderBrush="{DynamicResource TOrbitBorderBrush}"
                              Command="{Binding RestartCommand}"
                              IsEnabled="{Binding CanRestart}">
                        <materialIcons:MaterialIcon Kind="Refresh"
                                                    Width="16"
                                                    Height="16" />
                      </Button>
                      <Button Width="32"
                              Height="32"
                              Padding="0"
                              CornerRadius="999"
                              Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                              BorderBrush="{DynamicResource TOrbitBorderBrush}"
                              Command="{Binding StopCommand}"
                              IsEnabled="{Binding CanStop}">
                        <materialIcons:MaterialIcon Kind="Power"
                                                    Width="16"
                                                    Height="16" />
                      </Button>
                    </StackPanel>
                  </Grid>

                  <TextBlock Grid.Row="1"
                             Text="{Binding Description}"
                             Classes="caption-muted"
                             MinHeight="42"
                             MaxHeight="42"
                             MaxLines="2"
                             TextWrapping="Wrap" />

                  <designer:BadgeFlow Grid.Row="2"
                                      ItemsSource="{Binding CardTags}">
                    <designer:BadgeFlow.ItemTemplate>
                      <DataTemplate x:DataType="vm:PluginMonitorTagViewModel">
                        <Border Background="{Binding Background}"
                                CornerRadius="999"
                                Padding="10,4"
                                MinHeight="24"
                                VerticalAlignment="Center">
                          <TextBlock Text="{Binding Text}"
                                     FontSize="11"
                                     FontWeight="Medium"
                                     Foreground="{Binding Foreground}"
                                     VerticalAlignment="Center"
                                     TextAlignment="Center"
                                     LineHeight="14" />
                        </Border>
                      </DataTemplate>
                    </designer:BadgeFlow.ItemTemplate>
                  </designer:BadgeFlow>

                  <Border Grid.Row="3"
                          Padding="0,12,0,0"
                          BorderBrush="{DynamicResource TOrbitBorderBrush}"
                          BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                      <StackPanel Spacing="2">
                        <TextBlock Text="Last change"
                                   Classes="caption-muted"
                                   MinHeight="0" />
                        <TextBlock Text="{Binding StateChangedAtText}"
                                   FontSize="12" />
                      </StackPanel>

                      <StackPanel Grid.Column="1"
                                  Spacing="6"
                                  HorizontalAlignment="Right">
                        <TextBlock Text="Enabled"
                                   Classes="caption-muted"
                                   MinHeight="0"
                                   HorizontalAlignment="Right" />
                        <ToggleSwitch IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding CanToggleEnabled}"
                                      OffContent=""
                                      OnContent="" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Height="24"
                Background="Transparent" />
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
