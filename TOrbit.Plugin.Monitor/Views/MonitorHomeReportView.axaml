<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Monitor.ViewModels"
             xmlns:loc="using:TOrbit.Designer.Markup"
             x:Class="TOrbit.Plugin.Monitor.Views.MonitorHomeReportView"
             x:DataType="vm:MonitorHomeReportViewModel">

  <StackPanel Spacing="14">
    <Grid ColumnDefinitions="*,*"
          RowDefinitions="Auto,Auto"
          ColumnSpacing="12"
          RowSpacing="12">
      <Border Classes="panel"
              Padding="14,12">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Loc monitor.home.totalPlugins}"
                     Classes="caption-muted"
                     MinHeight="0" />
          <TextBlock Text="{Binding TotalCount}"
                     FontSize="22"
                     FontWeight="SemiBold" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1"
              Classes="panel"
              Padding="14,12">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Loc monitor.header.running}"
                     Classes="caption-muted"
                     MinHeight="0" />
          <TextBlock Text="{Binding RunningCount}"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TOrbitBadgeSuccessForegroundBrush}" />
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              Classes="panel"
              Padding="14,12">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Loc monitor.home.faultedPlugins}"
                     Classes="caption-muted"
                     MinHeight="0" />
          <TextBlock Text="{Binding FaultedCount}"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TOrbitBadgeDangerForegroundBrush}" />
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              Grid.Column="1"
              Classes="panel"
              Padding="14,12">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Loc monitor.header.diagnostics}"
                     Classes="caption-muted"
                     MinHeight="0" />
          <TextBlock Text="{Binding ErrorDiagnosticCount}"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TOrbitAccentBrush}" />
        </StackPanel>
      </Border>
    </Grid>

    <StackPanel Spacing="8">
      <TextBlock Text="{loc:Loc monitor.home.recentFaultedPlugins}"
                 Classes="subsection-title" />

      <StackPanel Spacing="8"
                  IsVisible="{Binding HasFaultedPlugins}">
        <ItemsControl ItemsSource="{Binding FaultedPlugins}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Classes="panel"
                      Padding="12,10"
                      Margin="0,0,0,8">
                <TextBlock Text="{Binding .}"
                           TextTrimming="CharacterEllipsis" />
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <TextBlock Text="{loc:Loc monitor.home.noFaultedPlugins}"
                 Classes="caption-muted"
                 IsVisible="{Binding !HasFaultedPlugins}" />
    </StackPanel>
  </StackPanel>
</UserControl>
